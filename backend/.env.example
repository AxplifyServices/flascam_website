NODE_ENV=development
PORT=3000
API_PREFIX=api

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flascam_db?schema=public"

FRONTEND_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3001"

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN="15m"

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN="7d"

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

UPLOAD_DIRECTORY="../uploads"
MAX_IMAGE_SIZE_MB=8
MAX_DOCUMENT_SIZE_MB=15
UPLOAD_MAX_VIDEO_SIZE_MB=200

S3_ENDPOINT=
S3_REGION=us-east-1

S3_ACCESS_KEY=
S3_SECRET_KEY=

S3_PUBLIC_BUCKET=flascam-public
S3_PRIVATE_BUCKET=flascam-private

S3_FORCE_PATH_STYLE=true

S3_PUBLIC_BASE_URL=

S3_SIGNED_URL_EXPIRATION_SECONDS=900

UPLOAD_MAX_IMAGE_SIZE_MB=10
UPLOAD_MAX_DOCUMENT_SIZE_MB=25
UPLOAD_MAX_VIDEO_SIZE_MB=250

PUBLIC_MEDIA_BASE_URL=http://localhost:9000/flascam-public