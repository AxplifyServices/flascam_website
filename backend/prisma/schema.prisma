/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model association_posts {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regional_association_id String                @db.Uuid
  content_type            String                @db.VarChar(30)
  status                  String                @default("DRAFT") @db.VarChar(30)
  title                   String                @db.VarChar(255)
  slug                    String                @db.VarChar(180)
  excerpt                 String?
  body                    String?
  cover_media_asset_id    String?               @db.Uuid
  event_start_at          DateTime?             @db.Timestamptz(6)
