/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model regional_associations {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(255)
  slug                    String                    @unique @db.VarChar(180)
  acronym                 String?                   @db.VarChar(40)
  region                  String                    @db.VarChar(180)
  city                    String?                   @db.VarChar(180)
  member_count            Int?
  affiliated_since_year   Int?
  logo_media_asset_id     String?                   @db.Uuid
  logo_text               String?                   @db.VarChar(12)
  presentation            String?
  address                 String?
  phone                   String?                   @db.VarChar(50)
  email                   String?                   @db.VarChar(255)
  website_url             String?
  facebook_url            String?
  instagram_url           String?
  linkedin_url            String?
  youtube_url             String?
  status                  String                    @default("DRAFT") @db.VarChar(30)
  is_featured             Boolean                   @default(false)
  display_order           Int                       @default(0)
  seo_title               String?                   @db.VarChar(255)
  seo_description         String?                   @db.VarChar(320)
  published_at            DateTime?                 @db.Timestamptz(6)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?                 @db.Timestamptz(6)
  association_media_items association_media_items[]
  association_posts       association_posts[]
  media_assets            media_assets?             @relation(fields: [logo_media_asset_id], references: [id], onUpdate: NoAction)
  users                   users[]

  @@index([deleted_at])
  @@index([is_featured, display_order], map: "regional_associations_featured_order_idx")
  @@index([region])
  @@index([status])
}

