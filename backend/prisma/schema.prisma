generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.Uuid
  description String?
  metadata    Json?
  ip_address  String?  @db.VarChar(64)
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)])
  @@index([entity_type, entity_id], map: "audit_logs_entity_idx")
  @@index([user_id])
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String             @unique @db.VarChar(100)
  name             String             @db.VarChar(150)
  description      String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique(map: "refresh_tokens_token_hash_unique")
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  ip_address String?   @db.VarChar(64)
  user_agent String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at])
  @@index([user_id])
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String             @unique @db.VarChar(50)
  name             String             @db.VarChar(100)
  description      String?
  is_system        Boolean            @default(false)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
  users            users[]
}

model users {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id             String           @db.Uuid
  email               String           @unique(map: "users_email_unique") @db.VarChar(255)
  password_hash       String
  first_name          String?          @db.VarChar(100)
  last_name           String?          @db.VarChar(100)
  phone               String?          @db.VarChar(30)
  is_active           Boolean          @default(true)
  is_email_verified   Boolean          @default(false)
  last_login_at       DateTime?        @db.Timestamptz(6)
  password_changed_at DateTime?        @db.Timestamptz(6)
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at          DateTime?        @db.Timestamptz(6)
  audit_logs          audit_logs[]
  media_assets        media_assets[]
  refresh_tokens      refresh_tokens[]
  roles               roles            @relation(fields: [role_id], references: [id], onUpdate: NoAction)

  @@index([deleted_at])
  @@index([is_active])
  @@index([role_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model media_assets {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploaded_by_user_id String?   @db.Uuid
  storage_provider    String    @default("S3") @db.VarChar(30)
  bucket_name         String    @db.VarChar(100)
  object_key          String
  original_filename   String
  stored_filename     String
  file_extension      String?   @db.VarChar(20)
  mime_type           String    @db.VarChar(150)
  media_type          String    @db.VarChar(30)
  visibility          String    @default("PRIVATE") @db.VarChar(20)
  status              String    @default("PENDING") @db.VarChar(30)
  size_bytes          BigInt
  checksum_sha256     String?   @db.VarChar(64)
  width               Int?
  height              Int?
  duration_seconds    Decimal?  @db.Decimal(12, 3)
  title               String?   @db.VarChar(255)
  alt_text            String?   @db.VarChar(255)
  caption             String?
  metadata            Json      @default("{}")
  uploaded_at         DateTime  @default(now()) @db.Timestamptz(6)
  validated_at        DateTime? @db.Timestamptz(6)
  deleted_at          DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  users               users?    @relation(fields: [uploaded_by_user_id], references: [id], onUpdate: NoAction)

  @@unique([bucket_name, object_key], map: "media_assets_bucket_object_unique")
  @@index([created_at(sort: Desc)])
  @@index([deleted_at])
  @@index([media_type])
  @@index([metadata], map: "media_assets_metadata_gin_idx", type: Gin)
  @@index([status])
  @@index([uploaded_by_user_id])
  @@index([visibility])
}
