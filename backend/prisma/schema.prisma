  regional_associations   regional_associations @relation(fields: [regional_association_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([regional_association_id, slug], map: "association_posts_slug_unique")
  @@index([regional_association_id], map: "association_posts_association_idx")
  @@index([deleted_at])
  @@index([event_start_at], map: "association_posts_event_start_idx")
  @@index([content_type, status], map: "association_posts_type_status_idx")
