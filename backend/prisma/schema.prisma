  missions_eyebrow         String?  @db.VarChar(180)
  missions_title           String?  @db.VarChar(255)
  missions_body            String?
  governance_eyebrow       String?  @db.VarChar(180)
  governance_title         String?  @db.VarChar(255)
  governance_body          String?
  executive_office_eyebrow String?  @db.VarChar(180)
